+func redactSerializableValue(def *Definition, value interface{}) interface{} {
+	if def == nil || def.Type != TypeSecret {
+		return value
+	}
+	if value == nil {
+		return nil
+	}
+	if s, ok := value.(string); ok && s == "" {
+		return ""
+	}
+	return redactedSecretValue
+}
+
+func redactSerializableMetadata(def *Definition, metadata map[string]interface{}) map[string]interface{} {
+	if def == nil || def.Type != TypeSecret || len(metadata) == 0 {
+		return metadata
+	}
+
+	ret := copyMetadata(metadata)
+	if _, ok := ret["map-value"]; ok {
+		ret["map-value"] = redactedSecretValue
+	}
+	return ret
+}
+
+func redactSerializableLog(def *Definition, log []ParseStep) []ParseStep {
+	if def == nil || def.Type != TypeSecret || len(log) == 0 {
+		return log
+	}
+
+	ret := make([]ParseStep, len(log))
+	for i, l := range log {
+		ret[i] = ParseStep{
+			Source:   l.Source,
+			Value:    redactSerializableValue(def, l.Value),
+			Metadata: redactSerializableMetadata(def, l.Metadata),
+		}
+	}
+	return ret
+}
+
+// ToSerializableFieldValue converts a FieldValue to its serializable representation.
