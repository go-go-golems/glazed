+package fields
+
+import (
+    "testing"
+
+    "github.com/stretchr/testify/require"
+)
+
+func TestToSerializableFieldValueRedactsSecretValuesAndMapValueMetadata(t *testing.T) {
+    def := New("api-key", TypeSecret)
+    fv := &FieldValue{Definition: def}
+    err := fv.Update("super-secret-token",
+        WithSource("config"),
+        WithMetadata(map[string]interface{}{
+            "config_file": "config.yaml",
+            "map-value":   "super-secret-token",
+        }),
+    )
+    require.NoError(t, err)
+
+    got := ToSerializableFieldValue(fv)
+    require.Equal(t, "***", got.Value)
+    require.Len(t, got.Log, 1)
+    require.Equal(t, "***", got.Log[0].Value)
+    require.Equal(t, "config.yaml", got.Log[0].Metadata["config_file"])
+    require.Equal(t, "***", got.Log[0].Metadata["map-value"])
+}
+
+func TestToSerializableFieldValueLeavesNonSecretValuesUntouched(t *testing.T) {
+    def := New("timeout", TypeInteger)
+    fv := &FieldValue{Definition: def}
+    err := fv.Update(30,
+        WithSource("defaults"),
+        WithMetadata(map[string]interface{}{"default": true}),
+    )
+    require.NoError(t, err)
+
+    got := ToSerializableFieldValue(fv)
+    require.Equal(t, 30, got.Value)
+    require.Len(t, got.Log, 1)
+    require.Equal(t, 30, got.Log[0].Value)
+    require.Equal(t, true, got.Log[0].Metadata["default"])
+}
