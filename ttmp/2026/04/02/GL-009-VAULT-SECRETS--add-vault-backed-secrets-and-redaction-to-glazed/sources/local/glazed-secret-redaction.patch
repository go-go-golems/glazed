+	}
 	return &SerializableFieldValue{
-		Value: pp.Value,
-		Log:   pp.Log,
+		Value: redactSerializableValue(pp.Definition, pp.Value),
+		Log:   redactSerializableLog(pp.Definition, pp.Log),
 	}
 }
 
