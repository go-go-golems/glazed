@@ -0,0 +1,32 @@
+package fields
+
+// SecretRef describes how a field should be loaded from a secret backend.
+// The middleware resolves these references through a provider-specific SecretResolver.
+type SecretRef struct {
+	Provider   string            `yaml:"provider,omitempty" json:"provider,omitempty"`
+	Identifier string            `yaml:"identifier,omitempty" json:"identifier,omitempty"`
+	Key        string            `yaml:"key,omitempty" json:"key,omitempty"`
+	Version    string            `yaml:"version,omitempty" json:"version,omitempty"`
+	Options    map[string]string `yaml:"options,omitempty" json:"options,omitempty"`
+}
+
+func (s *SecretRef) Clone() *SecretRef {
+	if s == nil {
+		return nil
+	}
+
+	ret := &SecretRef{
+		Provider:   s.Provider,
+		Identifier: s.Identifier,
+		Key:        s.Key,
+		Version:    s.Version,
+	}
+	if s.Options != nil {
+		ret.Options = make(map[string]string, len(s.Options))
+		for key, value := range s.Options {
+			ret.Options[key] = value
+		}
+	}
+
+	return ret
+}
