new file mode 100644
index 0000000..875bd99
--- /dev/null
+++ b/pkg/cmds/sources/secrets_test.go
@@ -0,0 +1,178 @@
+package sources_test
+
+import (
+	"context"
+	"testing"
+
+	"github.com/go-go-golems/glazed/pkg/cmds/fields"
+	"github.com/go-go-golems/glazed/pkg/cmds/schema"
+	"github.com/go-go-golems/glazed/pkg/cmds/sources"
+	"github.com/go-go-golems/glazed/pkg/cmds/values"
+	"github.com/stretchr/testify/require"
+)
+
+type mockSecretResolver struct {
+	lastBootstrap map[string]interface{}
+	secrets       map[string]map[string]string
+}
+
+func (m *mockSecretResolver) Name() string {
+	return "mock"
+}
+
+func (m *mockSecretResolver) Resolve(_ context.Context, bootstrap *values.Values, requests []sources.SecretRequest) (map[sources.SecretRequestKey]interface{}, error) {
+	m.lastBootstrap = map[string]interface{}{}
+	if bootstrap != nil {
+		m.lastBootstrap = bootstrap.GetDataMap()
+	}
+
+	ret := map[sources.SecretRequestKey]interface{}{}
+	for _, request := range requests {
+		providerSecrets := m.secrets[request.Ref.Identifier]
+		if providerSecrets == nil {
+			continue
+		}
+		if request.Ref.Key != "" {
+			ret[request.Key] = providerSecrets[request.Ref.Key]
+			continue
+		}
+		for _, value := range providerSecrets {
+			ret[request.Key] = value
+			break
+		}
+	}
+	return ret, nil
+}
+
+func newSecretsTestSchema(t *testing.T) *schema.Schema {
+	t.Helper()
+
+	configSection, err := schema.NewSection("config", "Config",
+		schema.WithFields(
+			fields.New("environment", fields.TypeString, fields.WithBootstrap(true)),
+			fields.New("region", fields.TypeString),
+		),
+	)
+	require.NoError(t, err)
+
+	appSection, err := schema.NewSection("app", "App",
+		schema.WithFields(
+			fields.New("database-password", fields.TypeCredentials,
+				fields.WithSecretRef(&fields.SecretRef{
+					Provider:   "mock",
+					Identifier: "db/{{ .environment }}",
+					Key:        "password",
+				}),
+			),
+			fields.New("api-token", fields.TypeSecret,
+				fields.WithSecretRef(&fields.SecretRef{
+					Provider:   "mock",
+					Identifier: "api/{{ .environment }}",
+					Key:        "token",
+				}),
+			),
+		),
+	)
+	require.NoError(t, err)
+
+	return schema.NewSchema(
+		schema.WithSection(configSection),
+		schema.WithSection(appSection),
+	)
+}
+
+func TestFromSecretsFirstPreParsesBootstrapFields(t *testing.T) {
+	schema_ := newSecretsTestSchema(t)
+	parsedValues := values.New()
+	resolver := &mockSecretResolver{
+		secrets: map[string]map[string]string{
+			"db/prod":  {"password": "prod-password"},
+			"api/prod": {"token": "prod-token"},
+		},
+	}
+
+	err := sources.Execute(
+		schema_,
+		parsedValues,
+		sources.FromSecretsFirst(
+			sources.WithSecretResolver(resolver),
+			sources.WithBootstrapMiddlewares(
+				sources.FromMap(map[string]map[string]interface{}{
+					"config": {"environment": "prod"},
+				}),
+			),
+		),
+	)
+	require.NoError(t, err)
+
+	require.Equal(t, map[string]interface{}{"environment": "prod"}, resolver.lastBootstrap)
+
+	configValues, ok := parsedValues.Get("config")
+	require.True(t, ok)
+	require.Equal(t, "prod", configValues.Fields.GetValue("environment"))
+
+	appValues, ok := parsedValues.Get("app")
+	require.True(t, ok)
+	require.Equal(t, "prod-password", appValues.Fields.GetValue("database-password"))
+	require.Equal(t, "prod-token", appValues.Fields.GetValue("api-token"))
+}
+
+func TestFromSecretsFillsDefaultsButDoesNotOverrideExplicitValues(t *testing.T) {
+	schema_ := newSecretsTestSchema(t)
+	parsedValues := values.New()
+	resolver := &mockSecretResolver{
+		secrets: map[string]map[string]string{
+			"db/prod":  {"password": "prod-password"},
+			"api/prod": {"token": "prod-token"},
+		},
+	}
+
+	err := sources.Execute(
+		schema_,
+		parsedValues,
+		sources.FromSecrets(
+			sources.WithSecretResolver(resolver),
+		),
+		sources.FromMap(map[string]map[string]interface{}{
+			"config": {"environment": "prod"},
+			"app":    {"api-token": "manual-token"},
+		}),
+		sources.FromDefaults(fields.WithSource(fields.SourceDefaults)),
+	)
+	require.NoError(t, err)
+
+	require.Equal(t, map[string]interface{}{"environment": "prod", "api-token": "manual-token"}, resolver.lastBootstrap)
+
+	appValues, ok := parsedValues.Get("app")
+	require.True(t, ok)
+	require.Equal(t, "prod-password", appValues.Fields.GetValue("database-password"))
+	require.Equal(t, "manual-token", appValues.Fields.GetValue("api-token"))
+}
+
+func TestFromSecretsOverrideModeReplacesExistingValues(t *testing.T) {
+	schema_ := newSecretsTestSchema(t)
+	parsedValues := values.New()
+	resolver := &mockSecretResolver{
+		secrets: map[string]map[string]string{
+			"api/prod": {"token": "resolved-token"},
+		},
+	}
+
+	err := sources.Execute(
+		schema_,
+		parsedValues,
+		sources.FromSecrets(
+			sources.WithSecretResolver(resolver),
+			sources.WithSecretPopulateMode(sources.SecretPopulateOverride),
+		),
+		sources.FromMap(map[string]map[string]interface{}{
+			"config": {"environment": "prod"},
+			"app":    {"api-token": "manual-token"},
+		}),
+	)
+	require.NoError(t, err)
+
+	appValues, ok := parsedValues.Get("app")
+	require.True(t, ok)
+	require.Equal(t, "resolved-token", appValues.Fields.GetValue("api-token"))
+}
