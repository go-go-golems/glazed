+++ b/pkg/cmds/sources/secrets.go
@@ -0,0 +1,496 @@
+package sources
+
+import (
+	"bytes"
+	"context"
+	"strings"
+	"text/template"
+
+	"github.com/go-go-golems/glazed/pkg/cmds/fields"
+	"github.com/go-go-golems/glazed/pkg/cmds/schema"
+	"github.com/go-go-golems/glazed/pkg/cmds/values"
+	"github.com/pkg/errors"
+)
+
+// SecretPopulateMode controls how secret-backed values are merged into parsed values.
+type SecretPopulateMode string
+
+const (
+	// SecretPopulateFillIfUnset only applies secret values when a field is unset or only has defaults.
+	SecretPopulateFillIfUnset SecretPopulateMode = "fill-if-unset"
+	// SecretPopulateOverride always applies secret values, even when the field already has a non-default value.
+	SecretPopulateOverride SecretPopulateMode = "override"
+)
+
+// SecretRequestKey identifies a field that should be populated from a secret backend.
+type SecretRequestKey struct {
+	SectionSlug string
+	FieldName   string
+}
+
+// SecretRequest represents a single secret-backed field resolved by a SecretResolver.
+type SecretRequest struct {
+	Key        SecretRequestKey
+	Section    schema.Section
+	Definition *fields.Definition
+	Ref        fields.SecretRef
+}
+
+// SecretResolver resolves secret-backed fields for one provider.
+type SecretResolver interface {
+	Name() string
+	Resolve(ctx context.Context, bootstrap *values.Values, requests []SecretRequest) (map[SecretRequestKey]interface{}, error)
+}
+
+// SecretResolverRegistry resolves resolvers by provider name.
+type SecretResolverRegistry interface {
+	Get(name string) (SecretResolver, bool)
+}
+
+type secretResolverRegistry map[string]SecretResolver
+
+func (r secretResolverRegistry) Get(name string) (SecretResolver, bool) {
+	resolver, ok := r[name]
+	return resolver, ok
+}
+
+type secretOptions struct {
+	ctx                  context.Context
+	resolvers            secretResolverRegistry
+	defaultProvider      string
+	mode                 SecretPopulateMode
+	parseOptions         []fields.ParseOption
+	bootstrapMiddlewares []Middleware
+	mergeBootstrapValues bool
+}
+
+// SecretOption configures secret resolution middleware.
+type SecretOption func(*secretOptions)
+
+// WithSecretResolver registers a single secret resolver.
+func WithSecretResolver(resolver SecretResolver) SecretOption {
+	return func(o *secretOptions) {
+		if resolver == nil {
+			return
+		}
+		if o.resolvers == nil {
+			o.resolvers = secretResolverRegistry{}
+		}
+		o.resolvers[resolver.Name()] = resolver
+	}
+}
+
+// WithSecretResolvers registers multiple secret resolvers.
+func WithSecretResolvers(resolvers ...SecretResolver) SecretOption {
+	return func(o *secretOptions) {
+		for _, resolver := range resolvers {
+			WithSecretResolver(resolver)(o)
+		}
+	}
+}
+
+// WithDefaultSecretProvider sets the provider used when a field-level secretRef omits provider.
+func WithDefaultSecretProvider(provider string) SecretOption {
+	return func(o *secretOptions) {
+		o.defaultProvider = provider
+	}
+}
+
+// WithSecretPopulateMode controls whether secret values fill only unset fields or override existing values.
+func WithSecretPopulateMode(mode SecretPopulateMode) SecretOption {
+	return func(o *secretOptions) {
+		o.mode = mode
+	}
+}
+
+// WithSecretParseOptions appends parse-step options when a secret value is applied.
+func WithSecretParseOptions(options ...fields.ParseOption) SecretOption {
+	return func(o *secretOptions) {
+		o.parseOptions = append(o.parseOptions, options...)
+	}
+}
+
+// WithBootstrapMiddlewares configures the middlewares used to pre-parse bootstrap fields.
+func WithBootstrapMiddlewares(middlewares ...Middleware) SecretOption {
+	return func(o *secretOptions) {
+		o.bootstrapMiddlewares = append(o.bootstrapMiddlewares, middlewares...)
+	}
+}
+
+// WithSecretsContext overrides the context passed to secret resolvers.
+func WithSecretsContext(ctx context.Context) SecretOption {
+	return func(o *secretOptions) {
+		if ctx != nil {
+			o.ctx = ctx
+		}
+	}
+}
+
+// WithMergeBootstrapValues controls whether parsed bootstrap values are merged into the final Values.
+func WithMergeBootstrapValues(merge bool) SecretOption {
+	return func(o *secretOptions) {
+		o.mergeBootstrapValues = merge
+	}
+}
+
+func newSecretOptions(options ...SecretOption) *secretOptions {
+	ret := &secretOptions{
+		ctx:                  context.Background(),
+		resolvers:            secretResolverRegistry{},
+		mode:                 SecretPopulateFillIfUnset,
+		mergeBootstrapValues: true,
+	}
+	for _, option := range options {
+		option(ret)
+	}
+	return ret
+}
+
+// FromSecrets resolves secret-backed fields after the rest of the middleware chain.
+// This is useful when secrets act like dynamic defaults and should only fill fields that
+// were not provided explicitly by later sources such as config, env, or CLI.
+func FromSecrets(options ...SecretOption) Middleware {
+	return func(next HandlerFunc) HandlerFunc {
+		return func(schema_ *schema.Schema, parsedValues *values.Values) error {
+			opts := newSecretOptions(options...)
+
+			if err := next(schema_, parsedValues); err != nil {
+				return err
+			}
+
+			bootstrapValues := parsedValues
+			if len(opts.bootstrapMiddlewares) > 0 {
+				parsedBootstrap, err := parseBootstrapValues(schema_, opts)
+				if err != nil {
+					return err
+				}
+				if parsedBootstrap != nil && parsedBootstrap.Len() > 0 {
+					bootstrapValues = parsedBootstrap
+				}
+			}
+
+			return resolveAndApplySecrets(schema_, parsedValues, bootstrapValues, opts)
+		}
+	}
+}
+
+// FromSecretsFirst resolves secret-backed fields after pre-parsing bootstrap fields but before
+// running the rest of the middleware chain. This lets secrets participate as an intermediate
+// source that later middlewares may still override.
+func FromSecretsFirst(options ...SecretOption) Middleware {
+	return func(next HandlerFunc) HandlerFunc {
+		return func(schema_ *schema.Schema, parsedValues *values.Values) error {
+			opts := newSecretOptions(options...)
+
+			bootstrapValues, err := parseBootstrapValues(schema_, opts)
+			if err != nil {
+				return err
+			}
+			if opts.mergeBootstrapValues && bootstrapValues != nil && bootstrapValues.Len() > 0 {
+				if err := parsedValues.Merge(bootstrapValues); err != nil {
+					return err
+				}
+			}
+
+			if err := resolveAndApplySecrets(schema_, parsedValues, bootstrapValues, opts); err != nil {
+				return err
+			}
+
+			return next(schema_, parsedValues)
+		}
+	}
+}
+
+func parseBootstrapValues(schema_ *schema.Schema, opts *secretOptions) (*values.Values, error) {
+	if len(opts.bootstrapMiddlewares) == 0 {
+		return values.New(), nil
+	}
+
+	fieldsBySection := collectBootstrapFields(schema_)
+	if len(fieldsBySection) == 0 {
+		return values.New(), nil
+	}
+
+	bootstrapSchema := schema_.Clone()
+	if err := WhitelistSectionFieldsHandler(fieldsBySection)(bootstrapSchema, values.New()); err != nil {
+		return nil, err
+	}
+
+	bootstrapValues := values.New()
+	if err := Execute(bootstrapSchema, bootstrapValues, opts.bootstrapMiddlewares...); err != nil {
+		return nil, err
+	}
+
+	return bootstrapValues, nil
+}
+
+func collectBootstrapFields(schema_ *schema.Schema) map[string][]string {
+	ret := map[string][]string{}
+	schema_.ForEach(func(slug string, section schema.Section) {
+		section.GetDefinitions().ForEach(func(definition *fields.Definition) {
+			if definition.Bootstrap {
+				ret[slug] = append(ret[slug], definition.Name)
+			}
+		})
+	})
+	return ret
+}
+
+func resolveAndApplySecrets(schema_ *schema.Schema, parsedValues *values.Values, bootstrapValues *values.Values, opts *secretOptions) error {
+	requests, err := collectSecretRequests(schema_, bootstrapValues)
+	if err != nil {
+		return err
+	}
+	if len(requests) == 0 {
+		return nil
+	}
+
+	updates, err := resolveSecretUpdates(bootstrapValues, requests, opts)
+	if err != nil {
+		return err
+	}
+
+	return applySecretUpdates(parsedValues, requests, updates, opts)
+}
+
+func collectSecretRequests(schema_ *schema.Schema, templateValues *values.Values) ([]SecretRequest, error) {
+	ret := make([]SecretRequest, 0)
+	templateContext := buildSecretTemplateContext(templateValues)
+
+	err := schema_.ForEachE(func(slug string, section schema.Section) error {
+		return section.GetDefinitions().ForEachE(func(definition *fields.Definition) error {
+			if definition.SecretRef == nil {
+				return nil
+			}
+
+			ref, err := renderSecretRef(definition.SecretRef, templateContext)
+			if err != nil {
+				return errors.Wrapf(err, "failed to render secret ref for %s.%s", slug, definition.Name)
+			}
+			if strings.TrimSpace(ref.Identifier) == "" {
+				return errors.Errorf("secret ref for %s.%s is missing identifier", slug, definition.Name)
+			}
+
+			ret = append(ret, SecretRequest{
+				Key: SecretRequestKey{
+					SectionSlug: slug,
+					FieldName:   definition.Name,
+				},
+				Section:    section,
+				Definition: definition,
+				Ref:        *ref,
+			})
+			return nil
+		})
+	})
+	if err != nil {
+		return nil, err
+	}
+
+	return ret, nil
+}
+
+func buildSecretTemplateContext(v *values.Values) map[string]interface{} {
+	ret := map[string]interface{}{}
+	if v == nil {
+		ret["Values"] = map[string]interface{}{}
+		ret["Sections"] = map[string]map[string]interface{}{}
+		return ret
+	}
+
+	flatValues := v.GetDataMap()
+	sections := map[string]map[string]interface{}{}
+	v.ForEach(func(slug string, sectionValues *values.SectionValues) {
+		sectionData := map[string]interface{}{}
+		sectionValues.Fields.ForEach(func(key string, value *fields.FieldValue) {
+			sectionData[key] = value.Value
+		})
+		sections[slug] = sectionData
+	})
+
+	ret["Values"] = flatValues
+	ret["Sections"] = sections
+	for key, value := range flatValues {
+		if _, ok := ret[key]; !ok {
+			ret[key] = value
+		}
+	}
+
+	return ret
+}
+
+func renderSecretRef(ref *fields.SecretRef, templateContext map[string]interface{}) (*fields.SecretRef, error) {
+	if ref == nil {
+		return nil, nil
+	}
+
+	ret := ref.Clone()
+	var err error
+	ret.Provider, err = renderTemplateString(ret.Provider, templateContext)
+	if err != nil {
+		return nil, err
+	}
+	ret.Identifier, err = renderTemplateString(ret.Identifier, templateContext)
+	if err != nil {
+		return nil, err
+	}
+	ret.Key, err = renderTemplateString(ret.Key, templateContext)
+	if err != nil {
+		return nil, err
+	}
+	ret.Version, err = renderTemplateString(ret.Version, templateContext)
+	if err != nil {
+		return nil, err
+	}
+	if ret.Options != nil {
+		for key, value := range ret.Options {
+			rendered, err := renderTemplateString(value, templateContext)
+			if err != nil {
+				return nil, err
+			}
+			ret.Options[key] = rendered
+		}
+	}
+	return ret, nil
+}
+
+func renderTemplateString(value string, templateContext map[string]interface{}) (string, error) {
+	if !strings.Contains(value, "{{") {
+		return value, nil
+	}
+
+	tmpl, err := template.New("secret-ref").Option("missingkey=error").Parse(value)
+	if err != nil {
+		return "", err
+	}
+
+	var buffer bytes.Buffer
+	if err := tmpl.Execute(&buffer, templateContext); err != nil {
+		return "", err
+	}
+	return buffer.String(), nil
+}
+
+func resolveSecretUpdates(bootstrapValues *values.Values, requests []SecretRequest, opts *secretOptions) (map[SecretRequestKey]interface{}, error) {
+	grouped := map[string][]SecretRequest{}
+	for _, request := range requests {
+		provider, err := resolveRequestProvider(request.Ref, opts)
+		if err != nil {
+			return nil, err
+		}
+		grouped[provider] = append(grouped[provider], request)
+	}
+
+	ret := map[SecretRequestKey]interface{}{}
+	for provider, groupedRequests := range grouped {
+		resolver, ok := opts.resolvers.Get(provider)
+		if !ok {
+			return nil, errors.Errorf("no secret resolver registered for provider %s", provider)
+		}
+		updates, err := resolver.Resolve(opts.ctx, bootstrapValues, groupedRequests)
+		if err != nil {
+			return nil, errors.Wrapf(err, "failed to resolve secrets for provider %s", provider)
+		}
+		for key, value := range updates {
+			ret[key] = value
+		}
+	}
+
+	return ret, nil
+}
+
+func resolveRequestProvider(ref fields.SecretRef, opts *secretOptions) (string, error) {
+	provider := strings.TrimSpace(ref.Provider)
+	if provider != "" {
+		return provider, nil
+	}
+	if strings.TrimSpace(opts.defaultProvider) != "" {
+		return strings.TrimSpace(opts.defaultProvider), nil
+	}
+	if len(opts.resolvers) == 1 {
+		for name := range opts.resolvers {
+			return name, nil
+		}
+	}
+	return "", errors.Errorf("secret ref for %s does not specify a provider", ref.Identifier)
+}
+
+func applySecretUpdates(parsedValues *values.Values, requests []SecretRequest, updates map[SecretRequestKey]interface{}, opts *secretOptions) error {
+	requestsByKey := map[SecretRequestKey]SecretRequest{}
+	for _, request := range requests {
+		requestsByKey[request.Key] = request
+	}
+
+	for key, value := range updates {
+		request, ok := requestsByKey[key]
+		if !ok {
+			continue
+		}
+
+		sectionValues := parsedValues.GetOrCreate(request.Section)
+		existing, hasExisting := sectionValues.Fields.Get(request.Definition.Name)
+		if !shouldApplySecretValue(existing, hasExisting, opts.mode) {
+			continue
+		}
+
+		parseOptions := make([]fields.ParseOption, 0, len(opts.parseOptions)+2)
+		parseOptions = append(parseOptions,
+			fields.WithSource("secret:"+resolveAppliedProvider(request.Ref, opts)),
+			fields.WithMetadata(secretUpdateMetadata(request.Ref, opts)),
+		)
+		parseOptions = append(parseOptions, opts.parseOptions...)
+
+		if err := sectionValues.Fields.UpdateValue(request.Definition.Name, request.Definition, value, parseOptions...); err != nil {
+			return err
+		}
+	}
+	return nil
+}
+
+func resolveAppliedProvider(ref fields.SecretRef, opts *secretOptions) string {
+	provider, err := resolveRequestProvider(ref, opts)
+	if err != nil {
+		return "secret"
+	}
+	return provider
+}
+
+func secretUpdateMetadata(ref fields.SecretRef, opts *secretOptions) map[string]interface{} {
+	ret := map[string]interface{}{}
+	provider := resolveAppliedProvider(ref, opts)
+	if provider != "" {
+		ret["secret_provider"] = provider
+	}
+	if ref.Identifier != "" {
+		ret["secret_identifier"] = ref.Identifier
+	}
+	if ref.Key != "" {
+		ret["secret_key"] = ref.Key
+	}
+	if ref.Version != "" {
+		ret["secret_version"] = ref.Version
+	}
+	return ret
+}
+
+func shouldApplySecretValue(existing *fields.FieldValue, hasExisting bool, mode SecretPopulateMode) bool {
+	if mode == SecretPopulateOverride {
+		return true
+	}
+	if !hasExisting || existing == nil {
+		return true
+	}
+	if len(existing.Log) == 0 {
+		return false
+	}
+	for _, step := range existing.Log {
+		source := strings.TrimSpace(step.Source)
+		switch source {
+		case "default", fields.SourceDefaults:
+			continue
+		default:
+			return false
+		}
+	}
+	return true
+}
