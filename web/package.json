{
  "name": "@glazed/help-browser-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir dist/ssr",
    "build:all": "pnpm build && pnpm build:ssr",
    "ssr": "node server.mjs",
